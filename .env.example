# Agent Zero Environment Configuration

# API Keys for Cloud LLM Providers
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# Ollama Models (pulled inside Docker container on first run)
# Note: Models must be pulled inside container even if you have them on host
OLLAMA_MODEL=qwen3:4b
OLLAMA_CODER_MODEL=qwen3-coder:30b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Search Engine Selection (searxng or perplexity)
SEARCH_ENGINE=searxng

# Perplexity API Key (only needed if SEARCH_ENGINE=perplexity)
PERPLEXITY_API_KEY=your_perplexity_key_here

# n8n Configuration
N8N_API_KEY=your_n8n_api_key_here
N8N_ENCRYPTION_KEY=your_n8n_encryption_key_here

# PostgreSQL (n8n database)
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_secure_password

# Agent Zero Settings
DEFAULT_MODEL_PROVIDER=ollama
DEFAULT_MODEL=qwen3:4b

# Docker Model Pull Instructions
# After starting the container, pull models with:
#   docker exec agent-zero-unified ollama pull qwen3:4b
#   docker exec agent-zero-unified ollama pull qwen3-coder:30b
#   docker exec agent-zero-unified ollama pull nomic-embed-text
#
# Why pull inside container?
# Docker containers have isolated filesystems.
# Even if you have Ollama models on your host system,
# the Ollama instance inside the container cannot access them.
