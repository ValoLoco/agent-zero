# Agent Zero Configuration

# Ollama LLM
OLLAMA_URL=http://ollama:11434
# Default models (pull after startup):
# docker exec ollama ollama pull gemma2:9b
# docker exec ollama ollama pull nomic-embed-text

# n8n Workflow Automation
N8N_URL=http://n8n:5678
N8N_API_KEY=  # Optional: Generate in n8n UI → Settings → API

# Database (auto-configured by docker-compose)
DB_TYPE=postgresdb
DB_HOST=postgres
DB_PORT=5432
DB_NAME=n8n
DB_USER=n8n
DB_PASSWORD=n8n

# Agent Zero
AGENT_NAME=OneBot
AGENT_PERSONALITY=professional
MEMORY_PATH=/app/memory
FOAM_PATH=/app/foam

# Optional: Cloud LLM fallback (if Ollama unavailable)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
